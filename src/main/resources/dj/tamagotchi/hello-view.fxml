<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dj.tamagotchi.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <ImageView id="Image" fx:id="petImage" fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
      <ButtonBar id="Image" prefHeight="40.0" prefWidth="200.0" VBox.vgrow="NEVER">
        <buttons>
                <Button fx:id="eatButton" mnemonicParsing="false" onAction="#onEatButtonClick" text="Eat" />
            <Button fx:id="playButton" mnemonicParsing="false" onAction="#onPlayButtonClick" text="Play" />
          <Button fx:id="sleepButton" mnemonicParsing="false" onAction="#onSleepButtonClick" text="Sleep">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets></Button>
        </buttons>
         <VBox.margin>
            <Insets />
         </VBox.margin>
         <padding>
            <Insets right="10.0" />
         </padding>
      </ButtonBar>
   </children>
</VBox>
